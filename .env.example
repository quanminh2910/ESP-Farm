AIO_USERNAME=your_adafruit_username
AIO_KEY=your_adafruit_key
TEMP_HIGH_THRESHOLD=37
TEMP_LOW_THRESHOLD=35

# Supabase Configuration
# Get these from your Supabase project settings at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_DB_TIMEOUT=10

# Sensor & Device ID Mappings
# These should match the IDs in your Supabase database (sensors and devices tables)
TEMPERATURE_SENSOR_ID=1
HUMIDITY_SENSOR_ID=2
SOIL_SENSOR_ID=3
MOISTURE_SENSOR_ID=3
PUMP_DEVICE_ID=1
FAN_DEVICE_ID=2
LED_DEVICE_ID=3

# System User ID for automation actions
# This user ID is used for automated control actions (no manual user interaction)
SYSTEM_USER_ID=1

# FastAPI bridge runtime
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Serial (Yolobit)
SERIAL_PORT=COM3
SERIAL_BAUDRATE=115200
SERIAL_TIMEOUT_SEC=1.0
SERIAL_RECONNECT_INTERVAL_SEC=30.0
